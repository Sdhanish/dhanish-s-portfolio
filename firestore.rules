rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Portfolio Content Collections - Readable and writable for portfolio management
    match /personalInfo/{docId} {
      allow read, write: if true;
    }

    match /projects/{docId} {
      allow read, write: if true;
    }

    match /skills/{docId} {
      allow read, write: if true;
    }

    match /services/{docId} {
      allow read, write: if true;
    }

    match /timeline/{docId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    // Messages Collection - Creation public for contact form, management by Admin
    match /messages/{docId} {
      allow read, write: if true;
    }
  }
}

